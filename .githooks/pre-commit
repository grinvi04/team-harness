#!/bin/sh
# 계층 0.5: git 네이티브 커밋 가드 — AI 도구·사람 구분 없이 모든 커밋에 적용
# 활성화(클론 후 1회): git config core.hooksPath .githooks
# 참고: git merge가 만드는 머지 커밋은 이 훅을 타지 않는다 (/release·/hotfix 플로우 정상)

branch=$(git branch --show-current)
if [ "$branch" = "main" ] || [ "$branch" = "develop" ]; then
  echo "⛔ [pre-commit] $branch 브랜치 직접 커밋 금지"
  echo "   feature/fix/hotfix/release 브랜치에서 작업 후 PR로 머지하세요"
  echo "   (긴급 우회: --no-verify — 사용 시 팀 리드에게 보고)"
  exit 1
fi

if ! command -v gitleaks >/dev/null 2>&1; then
  echo "⛔ [pre-commit] gitleaks가 없어 staged secret scan을 실행할 수 없습니다"
  echo "   해결: https://github.com/gitleaks/gitleaks 설치 후 다시 커밋하세요"
  exit 1
fi
if ! gitleaks git --pre-commit --staged --redact=100 --no-banner .; then
  echo "⛔ [pre-commit] staged 변경에서 시크릿 의심값이 감지됐습니다"
  exit 1
fi
exit 0
